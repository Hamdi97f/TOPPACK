# api-gateway webapp
# Base URL for the remote api-gateway (defaults to the production endpoint).
TOPPACK_API_BASE_URL="https://hycvkzijiwnmcwejvugj.supabase.co/functions/v1/api-gateway"

# Project API key issued by the webapp. Required for every server-side
# request. Server-side only — never exposed to the browser.
TOPPACK_API_KEY="your-project-api-key"

# Service-account credentials used for anonymous catalog browsing
# (the api-gateway requires a bearer token even for /products and /categories).
# Create a regular non-admin user in your webapp and use those credentials here.
TOPPACK_SERVICE_EMAIL="catalog-reader@example.com"
TOPPACK_SERVICE_PASSWORD="change-me"

# NextAuth
# In production set NEXTAUTH_URL to your public site URL (e.g. https://toppackexpress.netlify.app)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
