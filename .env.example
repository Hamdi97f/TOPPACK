# Database (PostgreSQL — required for serverless deploys on Netlify/Vercel)
# Use a hosted Postgres provider (Neon, Supabase, Vercel Postgres, RDS, etc.)
# or a local Postgres for development.
DATABASE_URL="postgresql://user:password@host:5432/toppack?schema=public"

# NextAuth
# In production set NEXTAUTH_URL to your public site URL (e.g. https://toppackexpress.netlify.app)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# Admin account
# These two variables serve TWO purposes:
#   1. They are used by `npm run db:seed` to create the initial admin user.
#   2. At runtime, NextAuth will accept these credentials as a valid ADMIN
#      login even if the database has not been seeded (or is unreachable).
# Set these in your hosting provider's environment variables (e.g. Netlify
# → Site configuration → Environment variables). Do NOT commit real values.
ADMIN_EMAIL="admin@toppack.local"
ADMIN_PASSWORD="change-me-to-a-strong-password"
ADMIN_NAME="TOPPACK Admin"
